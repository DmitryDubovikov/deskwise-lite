# Скопируй в .env (вне git). Env читается только в src/config.ts (контракт №4).
DW_PORT=3000
DW_LOG_LEVEL=info
# docker compose up -d db (docker-compose.yml в корне репо)
DW_DATABASE_URL=postgresql://dw:dw@localhost:5432/dw
# OpenAI: только датированный снапшот (…-YYYY-MM-DD) — config-схема это требует
DW_OPENAI_API_KEY=sk-...
DW_OPENAI_MODEL=gpt-4.1-nano-2025-04-14
